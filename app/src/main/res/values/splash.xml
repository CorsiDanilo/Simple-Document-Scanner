<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- The background of the splash screen -->
        <item name="windowSplashScreenBackground">@color/background_splash</item>
        <!-- The icon of the splash screen -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <!-- The theme to use for the activity after the splash screen -->
        <item name="postSplashScreenTheme">@style/Theme.SimpleDocumentScanner</item>
    </style>
</resources>
